# NWC Agent — Zero-Dependency Lightning Wallet Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never committed.

# Nostr Wallet Connect URL from your NWC-compatible wallet
# Supported: Alby Hub, LNCURL, CoinOS, Rizful, and any NIP-47 wallet
# Get yours: Wallet Settings → App Connections → New Connection → Copy pairing secret
ALBY_NWC_URL="nostr+walletconnect://..."
